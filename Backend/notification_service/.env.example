# MongoDB
MONGO_URL=your-mongodb-connection-string

# JWT (must match auth service secret)
JWT_SECRET=your-jwt-secret

# Server Port
PORT=3005

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Auth service base URL (used for broadcast audience resolution)
AUTH_SERVICE_BASE_URL=http://localhost:3000

# Minimum interval between broadcasts (in milliseconds)
BROADCAST_MIN_INTERVAL_MS=60000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration (Gmail OAuth2)
EMAIL_USER=your-email@gmail.com
CLIENT_ID=your-google-client-id
CLIENT_SECRET=your-google-client-secret
REFRESH_TOKEN=your-google-refresh-token

# RabbitMQ
RABBIT_URL=your-rabbitmq-url
